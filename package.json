{
  "name": "opencrab",
  "version": "0.1.0",
  "private": true,
  "main": ".opencrab-desktop/main.js",
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev --hostname 127.0.0.1",
    "dev:webpack": "node node_modules/next/dist/bin/next dev --hostname 127.0.0.1 --webpack",
    "build": "npm run build:web",
    "build:web": "node node_modules/next/dist/bin/next build",
    "brand:png": "bash scripts/generate_brand_pngs.sh",
    "check:system-agents": "node scripts/build_system_agents.mjs --check",
    "desktop:app": "npm run desktop:build && npm run desktop:build-shell && node scripts/desktop/launch-electron.mjs standalone",
    "desktop:build": "npm run build:web && node scripts/desktop/prepare-standalone.mjs",
    "desktop:build-shell": "node node_modules/typescript/bin/tsc -p tsconfig.desktop.json",
    "desktop:copy-runtime-assets": "node scripts/desktop/copy-runtime-assets.mjs",
    "desktop:dev": "npm run desktop:build-shell && node scripts/desktop/launch-electron.mjs dev",
    "desktop:dist:dir": "npm run desktop:build && npm run desktop:build-shell && node scripts/desktop/package-app.mjs",
    "desktop:dist:mac": "npm run desktop:dist:dir && node scripts/desktop/package-dmg.mjs",
    "desktop:prepare-standalone": "node scripts/desktop/prepare-standalone.mjs",
    "desktop:prodlike": "npm run desktop:build && node scripts/desktop/run-standalone.mjs",
    "desktop:run-standalone": "node scripts/desktop/run-standalone.mjs",
    "import:agency-agent": "node scripts/import_agency_agent.mjs",
    "import:agency-catalog": "node scripts/import_agency_catalog.mjs",
    "start": "node node_modules/next/dist/bin/next start",
    "lint": "node node_modules/eslint/bin/eslint.js",
    "test": "node node_modules/vitest/vitest.mjs run",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "clean:runtime": "node scripts/clean_runtime.mjs"
  },
  "dependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openai/codex-sdk": "^0.114.0",
    "chrome-devtools-mcp": "^0.20.3",
    "next": "16.1.6",
    "pdf-parse": "^2.4.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^41.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
